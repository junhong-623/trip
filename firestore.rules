rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usernames: public read (for username availability check), write only by owner
    match /usernames/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Trips: user can only access their own trips
    match /trips/{tripId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;

      match /people/{personId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/trips/$(tripId)).data.createdBy == request.auth.uid;
      }
      match /receipts/{receiptId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/trips/$(tripId)).data.createdBy == request.auth.uid;
      }
      match /photos/{photoId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/trips/$(tripId)).data.createdBy == request.auth.uid;
      }
      match /settlements/{settlementId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/trips/$(tripId)).data.createdBy == request.auth.uid;
      }
    }
  }
}
